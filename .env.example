# Copy this file to .env and adjust the values below.

# JWT signing secret. Use a long random string (>= 32 chars).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
PIANIFICA_SECRET=change-this-to-a-long-random-string

# Emergency master account — both the username and password are stored ONLY as
# Argon2id hashes (the clear values are never kept anywhere). Leave unset to use
# the built-in defaults. To set your own, generate hashes and paste them here:
#   python scripts/gen_master_hash.py "my-username"
#   python scripts/gen_master_hash.py "my strong password"
# PIANIFICA_MASTER_USER_HASH=$argon2id$v=19$m=65536,t=3,p=4$...
# PIANIFICA_MASTER_HASH=$argon2id$v=19$m=65536,t=3,p=4$...
