# Copy this file to .env and adjust the values below.

# JWT signing secret. Use a long random string (>= 32 chars).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
PIANIFICA_SECRET=change-this-to-a-long-random-string

# Emergency master account password — stored ONLY as an Argon2id hash (the clear
# password is never kept anywhere). Leave unset to use the built-in default.
# To rotate it, generate a hash and paste it here:
#   python scripts/gen_master_hash.py "my new strong password"
# PIANIFICA_MASTER_HASH=$argon2id$v=19$m=65536,t=3,p=4$...
